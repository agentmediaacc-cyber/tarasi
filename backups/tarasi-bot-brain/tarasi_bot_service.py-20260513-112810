def normalise(text):
    return (text or "").lower().strip()

def ticket_number(prefix="TRQ"):
    return f"{prefix}-{datetime.now().strftime('%Y%m%d')}-{str(uuid.uuid4())[:6].upper()}"

def detect_vehicle(message):
    msg = normalise(message)
    if "quantum" in msg or "van" in msg:
        return "quantum"
    if "minibus" in msg or "bus" in msg:
        return "minibus"
    if "suv" in msg:
        return "suv"
    if "vip" in msg or "executive" in msg:
        return "vip"
    return "sedan"

def extract_route(message):
    msg = normalise(message)
    patterns = [
        r"from\s+(.+?)\s+to\s+(.+)",
        r"(.+?)\s+to\s+(.+)",
    ]
    for p in patterns:
        m = re.search(p, msg)
        if m:
            return m.group(1).strip(" .,-"), m.group(2).strip(" .,-")
    return "", ""

def extract_passengers(message):
    msg = normalise(message)
    found = re.findall(r"\b(\d{1,2})\s*(people|passengers|pax|persons|person)?\b", msg)
    if found:
        return max(1, int(found[0][0]))
    return 1

def detect_service_type(message):
    msg = normalise(message)
    if any(x in msg for x in ["airport", "hosea", "kutako", "hikia", "flight"]):
        return "airport transfer"
    if any(x in msg for x in ["school", "learner", "student"]):
        return "school transport"
    if any(x in msg for x in ["tour", "safari", "sossusvlei", "etosha", "coast", "swakopmund"]):
        return "tour / long-distance"
    if any(x in msg for x in ["vip", "executive", "business", "corporate"]):
        return "VIP / corporate"
    return "shuttle"

def price_for_route(pickup, dropoff, vehicle="sedan"):
    p = normalise(pickup)
    d = normalise(dropoff)
    v = normalise(vehicle) or "sedan"

    for r in DEFAULT_ROUTES:
        if r["from"] in p and r["to"] in d:
            return round(r["price"] * VEHICLE_MULTIPLIERS.get(v, 1), 2), r["label"]

    if any(x in p+d for x in ["wanaheda", "katutura", "khomasdal", "eros", "pioneerspark", "cimbebasia", "klein windhoek"]):
        return 150, "Windhoek town pickup estimate"

    if "windhoek" in p and "windhoek" in d:
        return 100, "Windhoek local ride estimate"

    return 0, "Manual pricing required"

