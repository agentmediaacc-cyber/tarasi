def build_bot_reply(message, session_data=None):
    session_data = session_data or {}
    msg = normalise(message)

    if any(x in msg for x in ["fee", "fees", "price", "prices", "cost", "how much", "charge", "charges"]):
        return {
            "reply": fees_answer(),
            "session_data": session_data,
            "suggestions": ["Create a quote", "Airport transfer", "Town pickup", "VIP transport"]
        }

    pickup, dropoff = extract_route(message)
    vehicle = detect_vehicle(message)
    passengers = extract_passengers(message)

    if pickup:
        session_data["pickup"] = pickup
    if dropoff:
        session_data["dropoff"] = dropoff
    session_data["vehicle"] = vehicle
    session_data["passengers"] = passengers
    session_data["service_type"] = detect_service_type(message)

    price, label = price_for_route(session_data.get("pickup",""), session_data.get("dropoff",""), vehicle)

    if price:
        session_data["estimated_price"] = price
        reply = (
            f"Great, I can help with that. For {label} using {vehicle.title()}, "
            f"the estimated price is N${price:.2f}. "
            f"This is a guide price for {passengers} passenger(s). "
            "Would you like me to create a premium quotation PDF for you?"
        )
    else:
        reply = (
            "I can help with that. Please send me the pickup location, drop-off location, travel date, "
            "number of passengers and vehicle type. Then I can calculate the route and prepare a premium quote."
        )

    return {
        "reply": reply,
        "session_data": session_data,
        "suggestions": ["Create a quote", "Airport transfer", "Town pickup", "Tour package", "Talk to support"]
    }
