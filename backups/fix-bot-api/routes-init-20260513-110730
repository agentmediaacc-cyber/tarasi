def register_blueprints(app):
    for blueprint in [
        public_bp,
        auth_bp,
        booking_bp,
        track_bp,
        tour_bp,
        fleet_bp,
        support_bp,
        profile_bp,
        admin_bp,
        driver_bp,
        driver_plus_bp,
        partner_bp,
        health_bp,
        api_bp,
    ]:
        if blueprint.name not in app.blueprints:
            app.register_blueprint(blueprint)

